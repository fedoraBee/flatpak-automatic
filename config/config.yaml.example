auto_update: true
enable_snapshots: true
auto_notify: always

timer:
  schedule: daily
  delay: 1h
  minimum_delay: 1h

snapshots:
  enabled: true
  snapper_config: root
  snapper_descriptions:
    pre: "flatpak-automatic-pre"
    post: "flatpak-automatic-post"

# ==============================================================================
# Notification Routing Engine
# ==============================================================================
# 'title' and 'body_template' support state-aware routing.
# You may provide a flat string for universal application OR a dictionary
# specifying distinct 'success' and 'failure' values.
# Sub-plugins inherit from the group level unless explicitly overridden.
# ==============================================================================
notification_groups:
  - name: Full extended group example
    desktop_notify: true

    # Group-level state-aware defaults
    title:
      success: "[$(hostname)] flatpak-automatic: $UPDATE_COUNT new upgrades have been installed."
      failure: "[$(hostname)] flatpak-automatic: FAILED"
    body_template: default.md

    mails:
      to:
        - Bob Doe <bob-doe@mail.example.com>
        - Lily Doe <lily-doe@mail.example.com>
      from: Flatpak Automatic Bot <flatpak-automatic@noreply.example.org>

      # Plugin-level override for state-aware templates
      body_template:
        success: default_mail_success.md
        failure: default_mail_failure.md

    webhooks:
      urls:
        - https://webhook.site/a...
        - https://webhook.site/b...
      secret: "optional_hmac_secret"
      # Inherits 'title' and 'body_template' from group level

    apprise:
      urls:
        - discord://user:pass@example.com
        - telegram://user:pass@example.com
        - slack://user:pass@example.com
        - mailto://user:pass@example.com
      # Inherits 'title' and 'body_template' from group level

  - name: Minimal text-only fallback
    mails:
      to: admin@example.com
    # Universal flat string applied to both success and failure states
    body_template: minimal.txt
