Name:           flatpak-automatic
Epoch:          @@EPOCH@@
Version:        @@VERSION@@
Release:        @@REL_NUM@@%{?dist}
Summary:        Secure, systemd-native automation for Flatpak updates

License:        GPL-3.0-or-later
URL:            https://github.com/fedoraBee/flatpak-automatic
Source0:        https://github.com/fedoraBee/%{name}/archive/v%{version}/%{name}-%{version}.tar.gz

BuildArch:      noarch
BuildRequires:  make
BuildRequires:  systemd-rpm-macros

Requires:       flatpak
Requires:       python3
Requires:       python3dist(pyyaml)
Requires:       python3dist(dbus-python)
Requires:       snapper
Requires:       s-nail
Requires:       systemd
Recommends:     python3-apprise

%description
Flatpak Automatic is a secure, systemd-native automation wrapper for Flatpak
updates. It features Snapper-integrated atomic rollbacks, multi-channel
alerting (Apprise, Mail, Webhooks, Desktop), and supports both system-wide and
rootless user-level execution. Designed for reliability and ease of use, it
ensures your Flatpak environment remains current and resilient.

%package doc
Summary:        Documentation for %{name}
BuildArch:      noarch

%description doc
This package contains the detailed documentation and change logs for
%{name}.

%prep
# Use -c to create the directory before extracting, since the Makefile tar command packages the directory contents directly
%setup -q -c

%build
# Nothing to build

%install
make install DESTDIR=%{buildroot} PREFIX=%{_prefix} SYSCONFDIR=%{_sysconfdir}
install -d %{buildroot}%{_datadir}/applications
install -m 644 assets/flatpak-automatic.desktop %{buildroot}%{_datadir}/applications/
install -d %{buildroot}%{_datadir}/icons/hicolor/scalable/apps
install -m 644 assets/logo.svg %{buildroot}%{_datadir}/icons/hicolor/scalable/apps/flatpak-automatic.svg
install -d %{buildroot}%{_prefix}/lib/systemd/user
install -m 644 config/systemd/flatpak-automatic-user.service %{buildroot}%{_prefix}/lib/systemd/user/flatpak-automatic.service
install -m 644 config/systemd/flatpak-automatic-user.timer %{buildroot}%{_prefix}/lib/systemd/user/flatpak-automatic.timer



%check
# Basic verification of installed files in BuildRoot
#test -f ...

%post
%systemd_post %{name}.service %{name}.timer
# Wipe any existing bytecode cache to ensure freshness after install/update
find %{_datadir}/%{name} -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true

%preun
%systemd_preun %{name}.service %{name}.timer

%postun
%systemd_postun_with_restart %{name}.service %{name}.timer
if [ $1 -eq 0 ]; then
    # Wipe bytecode cache on total removal
    find %{_datadir}/%{name} -name "__pycache__" -type d -exec rm -rf {} + 2>/dev/null || true
fi

%files
%dir %{_sysconfdir}/flatpak-automatic
%dir %{_sysconfdir}/flatpak-automatic/templates
%config(noreplace) %{_sysconfdir}/flatpak-automatic/config.yaml
%config(noreplace) %{_sysconfdir}/flatpak-automatic/config.example.yaml
%config(noreplace) %{_sysconfdir}/flatpak-automatic/config.user.yaml
%config(noreplace) %{_sysconfdir}/flatpak-automatic/templates/*

%{_bindir}/flatpak-automatic
%{_mandir}/man1/flatpak-automatic.1*
%{_unitdir}/flatpak-automatic.service
%{_unitdir}/flatpak-automatic.timer

%{_datadir}/flatpak-automatic/
%{_prefix}/lib/systemd/user/flatpak-automatic.service
%{_prefix}/lib/systemd/user/flatpak-automatic.timer
%config(noreplace) %{_sysconfdir}/sysconfig/flatpak-automatic
%license LICENSE

# NOTE: The %%changelog directive is automatically appended by the python script during the build process.

%{_datadir}/applications/flatpak-automatic.desktop
%{_datadir}/icons/hicolor/scalable/apps/flatpak-automatic.svg

%files doc
%doc README.md CHANGELOG.md docs/development.md .github/CONTRIBUTING.md AGENTS.md MAINTAINERS.md
