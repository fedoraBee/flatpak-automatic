[Desktop Entry]
Name=Flatpak Automatic
Comment=Automatic update service for Flatpak apps
Exec=bash -c "/usr/bin/flatpak-automatic; echo ''; read -p 'Press Enter to close...'"
Icon=flatpak-automatic
Terminal=true
Type=Application
Categories=System;Utility;
Actions=RunAsRoot;

[Desktop Action RunAsRoot]
Name=Run as Administrator (Root)
Exec=bash -c "pkexec /usr/bin/flatpak-automatic; echo ''; read -p 'Press Enter to close...'"
