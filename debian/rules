#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	mkdir -p debian/flatpak-automatic/usr/bin
	mkdir -p debian/flatpak-automatic/etc/default
	install -m 755 src/flatpak-automatic.py debian/flatpak-automatic/usr/bin/flatpak-automatic
	install -m 644 config/sysconfig/flatpak-automatic debian/flatpak-automatic/etc/default/flatpak-automatic

override_dh_auto_test:
	# Skip tests during packaging since they run independently in the CI unit-tests job.
